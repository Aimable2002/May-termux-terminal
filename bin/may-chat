#!/usr/bin/env bash
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=../lib/common.sh
source "$SCRIPT_DIR/../lib/common.sh"

require_api_key
BASE_URL="$(get_base_url)"
MODEL="${1:-$(get_default_model)}"

echo "== Chat (model: $MODEL) =="
echo "Type your message, or 'exit' to quit."
echo

history_json="[]"

send_message() {
  local user_msg="$1"

  # Build the updated history safely via argv, not string interpolation.
  history_json="$(python3 - "$history_json" "$user_msg" <<'PYEOF'
import json, sys
history = json.loads(sys.argv[1])
history.append({"role": "user", "content": sys.argv[2]})
print(json.dumps(history))
PYEOF
)"

  local payload
  payload="$(python3 - "$MODEL" "$history_json" <<'PYEOF'
import json, sys
model, history = sys.argv[1], json.loads(sys.argv[2])
print(json.dumps({"model": model, "messages": history}))
PYEOF
)"

  local response
  response="$(curl -sS "$BASE_URL/chat/completions" \
    -H "Authorization: Bearer $API_KEY" \
    -H "Content-Type: application/json" \
    -d "$payload")"

  local tmpfile
  tmpfile="$(mktemp)"
  printf '%s' "$response" > "$tmpfile"

  local reply
  reply="$(python3 - "$tmpfile" <<'PYEOF'
import json, sys
with open(sys.argv[1]) as f:
    data = json.load(f)
if "error" in data:
    print("API error: " + str(data["error"]))
    sys.exit(1)
try:
    print(data["choices"][0]["message"]["content"])
except Exception:
    print("Unexpected response: " + json.dumps(data)[:500])
PYEOF
)"
  rm -f "$tmpfile"

  echo
  echo "$reply"
  echo

  history_json="$(python3 - "$history_json" "$reply" <<'PYEOF'
import json, sys
history = json.loads(sys.argv[1])
history.append({"role": "assistant", "content": sys.argv[2]})
print(json.dumps(history))
PYEOF
)"
}

while true; do
  read -r -p "> " msg
  if [ "$msg" = "exit" ] || [ "$msg" = "quit" ]; then
    break
  fi
  [ -z "$msg" ] && continue
  send_message "$msg"
done
