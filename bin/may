#!/usr/bin/env bash
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=../lib/common.sh
source "$SCRIPT_DIR/../lib/common.sh"

show_menu() {
  echo
  print_may_banner
  echo
  printf '%s\n' "${C_CYAN}  ────────────────────────────────────────${C_RESET}"
  printf '  %s%-14s%s %s\n' "$C_GREEN"   "may chat"      "$C_RESET" "Chat with AI"
  printf '  %s%-14s%s %s\n' "$C_GREEN"   "may agent"     "$C_RESET" "Agent mode (OpenCode)"
  printf '  %s%-14s%s %s\n' "$C_GREEN"   "may models"    "$C_RESET" "Browse models"
  printf '  %s%-14s%s %s\n' "$C_GREEN"   "may config"    "$C_RESET" "Change API key / provider"
  printf '  %s%-14s%s %s\n' "$C_YELLOW"  "may trading"   "$C_RESET" "Launch the MAY9 signal bot"
  printf '  %s%-14s%s %s\n' "$C_GREEN"   "may install X" "$C_RESET" "Install a package (X = name)"
  printf '%s\n' "${C_CYAN}  ────────────────────────────────────────${C_RESET}"
  if ! config_exists; then
    printf '%s\n' "${C_DIM}  (no API key set yet — run 'may config' to set one up)${C_RESET}"
  fi
  echo
  printf '%s\n' "${C_DIM}  This is a normal command — run it any time from your shell,${C_RESET}"
  printf '%s\n' "${C_DIM}  same as git, ls, or anything else. It never takes over your${C_RESET}"
  printf '%s\n' "${C_DIM}  terminal or blocks other commands.${C_RESET}"
  echo
}

install_package() {
  local pkg="${1:-}"
  if [ -z "$pkg" ]; then
    read -r -p "Package name to install: " pkg
  fi
  [ -z "$pkg" ] && return 0
  if command -v pkg >/dev/null 2>&1; then
    pkg install -y "$pkg"
  elif command -v apt >/dev/null 2>&1; then
    sudo apt install -y "$pkg"
  elif command -v brew >/dev/null 2>&1; then
    brew install "$pkg"
  else
    echo "No known package manager found (pkg/apt/brew)." >&2
  fi
}

# 'may' behaves exactly like any other real CLI tool: run it, it does one
# thing, then control returns immediately to your actual shell. It never
# reads a loop of input, never intercepts commands that aren't its own,
# and never stands between you and git/cd/curl/anything else. That's the
# whole point of building this on top of a real terminal instead of a
# custom app shell.
case "${1:-}" in
  chat)     shift; exec "$SCRIPT_DIR/may-chat" "$@" ;;
  agent)    shift; exec "$SCRIPT_DIR/may-agent" "$@" ;;
  models)   shift; exec "$SCRIPT_DIR/may-models" "$@" ;;
  config)   shift; exec "$SCRIPT_DIR/may-config" "$@" ;;
  trading)  shift; exec "$SCRIPT_DIR/may-trading" "$@" ;;
  install)  shift; install_package "${1:-}" ;;
  ""|help|menu|-h|--help) show_menu ;;
  *)
    echo "Unknown 'may' command: $1" >&2
    echo "Run 'may' with no arguments to see available commands." >&2
    exit 1
    ;;
esac
