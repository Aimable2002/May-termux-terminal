#!/usr/bin/env bash
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=../lib/common.sh
source "$SCRIPT_DIR/../lib/common.sh"

show_menu() {
  echo
  echo "  MAY — commands"
  echo "  ----------------------------------------"
  echo "  may chat        Chat with AI"
  echo "  may agent       Agent mode (OpenCode)"
  echo "  may models      Browse models"
  echo "  may config      Change API key / provider"
  echo "  may install X   Install a package (X = name)"
  echo "  ----------------------------------------"
  if ! config_exists; then
    echo "  (no API key set yet — run 'may config' to set one up)"
  fi
  echo "  This is a normal command — run it any time from your shell,"
  echo "  same as git, ls, or anything else. It never takes over your"
  echo "  terminal or blocks other commands."
  echo
}

install_package() {
  local pkg="${1:-}"
  if [ -z "$pkg" ]; then
    read -r -p "Package name to install: " pkg
  fi
  [ -z "$pkg" ] && return 0
  if command -v pkg >/dev/null 2>&1; then
    pkg install -y "$pkg"
  elif command -v apt >/dev/null 2>&1; then
    sudo apt install -y "$pkg"
  elif command -v brew >/dev/null 2>&1; then
    brew install "$pkg"
  else
    echo "No known package manager found (pkg/apt/brew)." >&2
  fi
}

# 'may' behaves exactly like any other real CLI tool: run it, it does one
# thing, then control returns immediately to your actual shell. It never
# reads a loop of input, never intercepts commands that aren't its own,
# and never stands between you and git/cd/curl/anything else. That's the
# whole point of building this on top of a real terminal instead of a
# custom app shell.
case "${1:-}" in
  chat)   shift; exec "$SCRIPT_DIR/may-chat" "$@" ;;
  agent)  shift; exec "$SCRIPT_DIR/may-agent" "$@" ;;
  models) shift; exec "$SCRIPT_DIR/may-models" "$@" ;;
  config) shift; exec "$SCRIPT_DIR/may-config" "$@" ;;
  install) shift; install_package "${1:-}" ;;
  ""|help|menu|-h|--help) show_menu ;;
  *)
    echo "Unknown 'may' command: $1" >&2
    echo "Run 'may' with no arguments to see available commands." >&2
    exit 1
    ;;
esac
