#!/usr/bin/env bash
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=../lib/common.sh
source "$SCRIPT_DIR/../lib/common.sh"

BOT_SRC_DIR="$HOME/.may-trading/May_perp_bot_example"
BOT_APP_DIR="$BOT_SRC_DIR/may9bot"

install_deps() {
  echo "Checking Python dependencies..."
  local pip_cmd="pip"
  command -v pip3 >/dev/null 2>&1 && pip_cmd="pip3"
  local pip_log
  pip_log="$(mktemp)"

  if ! (cd "$BOT_APP_DIR" && "$pip_cmd" install -q -r requirements.txt 2>"$pip_log"); then
    if grep -q "externally-managed-environment" "$pip_log" 2>/dev/null; then
      echo "System Python is externally managed — retrying with --break-system-packages..."
      (cd "$BOT_APP_DIR" && "$pip_cmd" install -q -r requirements.txt --break-system-packages)
    else
      cat "$pip_log" >&2
      rm -f "$pip_log"
      return 1
    fi
  fi
  rm -f "$pip_log"
}

# Cheap, local, no-network check: is everything in requirements.txt actually
# installed right now? Uses 'pip show' (reads local package metadata only)
# rather than hardcoding package names, so it can't drift out of sync with
# requirements.txt, and rather than re-running 'pip install' on every single
# launch (slow, needs network). Still catches the case where requirements.txt
# was never fully installed (e.g. a prior install.sh run failed partway
# through) — so 'may trading' never hands the user a raw ModuleNotFoundError.
deps_missing() {
  local pip_cmd="pip"
  command -v pip3 >/dev/null 2>&1 && pip_cmd="pip3"
  local pkg
  while IFS= read -r pkg; do
    [ -z "$pkg" ] && continue
    case "$pkg" in \#*) continue ;; esac
    # strip version specifiers / extras / whitespace, keep bare package name
    pkg="$(echo "$pkg" | sed -E 's/[[:space:]]*[<>=!~;].*//; s/\[.*\]//' | xargs)"
    [ -z "$pkg" ] && continue
    "$pip_cmd" show "$pkg" >/dev/null 2>&1 || return 0
  done < "$BOT_APP_DIR/requirements.txt"
  return 1
}

run_bot() {
  if [ ! -d "$BOT_SRC_DIR/.git" ]; then
    echo "Trading bot isn't installed yet." >&2
    echo "Run install.sh first — it sets up the bot as part of MAY's setup." >&2
    exit 1
  fi

  if deps_missing; then
    echo "Some required packages are missing — installing them now..."
    if ! install_deps; then
      echo "Couldn't install dependencies automatically. See the error above." >&2
      exit 1
    fi
    if deps_missing; then
      echo "Dependencies still missing after install — something's wrong with the environment." >&2
      exit 1
    fi
  fi

  echo
  echo "Launching MAY9 trading bot — Ctrl+C to stop."
  echo
  cd "$BOT_APP_DIR"
  exec python3 may9bot.py
}

do_update() {
  if [ ! -d "$BOT_SRC_DIR/.git" ]; then
    echo "Trading bot isn't installed yet. Run install.sh first." >&2
    exit 1
  fi
  echo "Pulling latest changes..."
  git -C "$BOT_SRC_DIR" pull
  install_deps
  echo
  echo "Updated. This did NOT restart the bot if it was already running —"
  echo "stop any running instance yourself, then run 'may trading' to start"
  echo "the updated version. Updates are never applied automatically while"
  echo "the bot is live, since it may be holding open positions."
}

case "${1:-}" in
  update|--update)
    do_update
    ;;
  "")
    run_bot
    ;;
  *)
    echo "Usage: may trading | may trading update" >&2
    exit 1
    ;;
esac
