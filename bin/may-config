#!/usr/bin/env bash
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=../lib/common.sh
source "$SCRIPT_DIR/../lib/common.sh"

echo "== MAY setup =="
echo
echo "You bring your own API key — nothing is billed or routed through us."
echo "Default provider is OpenRouter (https://openrouter.ai/keys), but any"
echo "OpenAI-compatible endpoint works too."
echo

current_key="$(config_get api_key)"
if [ -n "$current_key" ]; then
  masked="${current_key: -4}"
  echo "Current key on file: ****$masked"
fi

read -r -p "Paste your API key (leave blank to keep current): " new_key
read -r -p "Base URL [${MAY_DEFAULT_BASE_URL}]: " new_base_url
read -r -p "Default model [meta-llama/llama-3.1-8b-instruct:free]: " new_model

if [ -z "$new_key" ] && [ -z "$current_key" ]; then
  echo "No key provided — you can run 'may config' again any time." >&2
fi

args=()
if [ -n "$new_key" ]; then
  args+=(api_key "$new_key")
fi
if [ -n "$new_base_url" ]; then
  args+=(base_url "$new_base_url")
fi
if [ -n "$new_model" ]; then
  args+=(default_model "$new_model")
fi

if [ "${#args[@]}" -gt 0 ]; then
  config_set "${args[@]}"
  echo
  echo "Saved to $MAY_CONFIG_FILE"
else
  echo "Nothing changed."
fi
